{
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.vulkran.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
